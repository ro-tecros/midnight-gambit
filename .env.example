# =============================================================================
#  Midnight Gambit · variables de entorno (copia este archivo a .env)
#  Para Docker Compose basta con definir aquí los valores; docker-compose.yml
#  los lee automáticamente.
# =============================================================================

# --- Aplicación ---
APP_PORT=4000
NODE_ENV=production

# --- Seguridad (¡CAMBIA ESTO EN PRODUCCIÓN!) ---
# Usa una cadena larga y aleatoria (mínimo 32 caracteres).
JWT_SECRET=please-change-this-secret-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- CORS ---
# '*' permite cualquier origen. En producción indica tu dominio, p.ej:
# CORS_ORIGIN=https://midnightgambit.tudominio.com
CORS_ORIGIN=*

# --- Base de datos PostgreSQL ---
PGUSER=chess
PGPASSWORD=chess
PGDATABASE=chess
PGPORT=5432

# --- Tiempos de gracia (segundos) ---
# Tiempo para reconectar antes de marcar abandono / declarar derrota.
RECONNECT_GRACE_SECONDS=60
ABANDON_GRACE_SECONDS=30
