# Variables para ejecutar el SERVIDOR de forma local sin Docker.
# Copia a server/.env y ajusta. Requiere un PostgreSQL accesible.

PORT=4000
NODE_ENV=development

JWT_SECRET=dev-secret-change-me-please-32-characters-min
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Conexión a PostgreSQL: usa DATABASE_URL o las variables PG* sueltas.
DATABASE_URL=postgres://chess:chess@localhost:5432/chess
# PGHOST=localhost
# PGPORT=5432
# PGUSER=chess
# PGPASSWORD=chess
# PGDATABASE=chess

RECONNECT_GRACE_SECONDS=60
ABANDON_GRACE_SECONDS=30
